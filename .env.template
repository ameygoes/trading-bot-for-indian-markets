# ═══════════════════════════════════════════════════════════════
#  .env.template — copy to .env and fill in real values
#  NEVER commit .env to git
# ═══════════════════════════════════════════════════════════════

# ── Trading Mode ─────────────────────────────────────────────
LIVE_TRADING=false               # true = real money; false = paper

# ── Notification Provider ─────────────────────────────────────
# Options: "telegram" | "openclaw" | "console"
NOTIFICATION_PROVIDER=console

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── OpenClaw (stub — fill when ready) ────────────────────────
OPENCLAW_API_KEY=
OPENCLAW_WEBHOOK_URL=

# ── Broker — Zerodha Kite ─────────────────────────────────────
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=                    # refreshed daily via login flow

# ── Broker — Upstox (fallback) ───────────────────────────────
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_ACCESS_TOKEN=

# ── Social / News APIs ────────────────────────────────────────
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=IndianMarketBot/1.0

TWITTER_BEARER_TOKEN=your_twitter_bearer_token

SERPAPI_KEY=                          # optional — for Google search results

# ── LLM (Claude API — research self-improvement) ─────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Database Paths ────────────────────────────────────────────
TRADES_DB_PATH=data/trades.db
RESEARCH_DB_PATH=data/research.db
PORTFOLIO_DB_PATH=data/portfolio.db

# ── MCP Server ────────────────────────────────────────────────
MCP_SERVER_PORT=8080
